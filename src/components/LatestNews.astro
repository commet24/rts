---
import { formatNewsDate, getPublishedNews, newsSlug } from '@data/news';

const news = (await getPublishedNews()).slice(0, 3);
---

{
  news.length > 0 && (
    <section class="news-section" id="news" aria-labelledby="news-title">
      <div class="section-heading">
        <h2 id="news-title">Новости</h2>
      </div>

      <div class="news-grid">
        {news.map((entry) => (
          <a class="news-card" href={`/news/${newsSlug(entry.id)}/`}>
            <time datetime={entry.data.date.toISOString()}>
              {formatNewsDate(entry.data.date)}
            </time>
            <h3>{entry.data.title}</h3>
            <p>{entry.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )
}
