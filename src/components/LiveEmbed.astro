---
import { liveEmbed } from '@data/live';
import { siteConfig } from '@data/site.config';

const iframeTitle = `${siteConfig.live.title} ${siteConfig.siteName}`;
---

<section class="hero-section" id="live" aria-labelledby="live-title">
  <div class="hero-copy">
    <h1 id="live-title">{siteConfig.live.title}</h1>
    <p class="hero-description">{siteConfig.live.description}</p>
  </div>

  <div class="player-card">
    <div class="player-frame" aria-label="Плеер прямого эфира">
      {
        liveEmbed.hlsUrl ? (
          <video
            class="player-video"
            controls
            playsinline
            preload="metadata"
            aria-label={iframeTitle}
            data-hls-src={liveEmbed.hlsUrl}
          >
            <a href={liveEmbed.sourcePageUrl} target="_blank" rel="noreferrer">
              Открыть трансляцию
            </a>
          </video>
        ) : liveEmbed.hasGeneratedPlayer && liveEmbed.embedUrl ? (
          <iframe
            src={liveEmbed.embedUrl}
            title={iframeTitle}
            loading="eager"
            referrerpolicy="strict-origin-when-cross-origin"
            allow="autoplay; fullscreen; picture-in-picture; encrypted-media"
            sandbox="allow-scripts allow-same-origin allow-presentation"
            allowfullscreen
          />
        ) : (
          <div class="player-fallback">
            <p>Эфир временно недоступен.</p>
            <a
              class="source-link source-link--button"
              href={liveEmbed.sourcePageUrl}
              target="_blank"
              rel="noreferrer"
            >
              Открыть трансляцию
            </a>
          </div>
        )
      }
    </div>
  </div>
</section>

<script>
  const videos = document.querySelectorAll<HTMLVideoElement>(
    'video[data-hls-src]',
  );

  for (const video of videos) {
    const hlsSrc = video.dataset.hlsSrc;

    if (!hlsSrc) {
      continue;
    }

    if (video.canPlayType('application/vnd.apple.mpegurl')) {
      video.src = hlsSrc;
      continue;
    }

    const { default: Hls } = await import('hls.js/light');

    if (Hls.isSupported()) {
      const hls = new Hls({
        enableWorker: true,
        lowLatencyMode: true,
      });
      hls.loadSource(hlsSrc);
      hls.attachMedia(video);
    }
  }
</script>
