---
import { partners } from '@data/partners';

const placeholders = Array.from({ length: 6 }, (_, index) => ({
  id: `placeholder-${index}`,
}));

const carouselItems =
  partners.length > 0
    ? partners.map((partner) => ({ type: 'partner' as const, partner }))
    : placeholders.map((placeholder) => ({
        type: 'placeholder' as const,
        placeholder,
      }));

const hasPartners = partners.length > 0;
const loopItems = hasPartners
  ? [
      ...carouselItems.map((item) => ({ ...item, isDuplicate: false })),
      ...carouselItems.map((item) => ({ ...item, isDuplicate: true })),
    ]
  : carouselItems.map((item) => ({ ...item, isDuplicate: false }));
---

<section
  class="partners-section"
  id="partners"
  aria-labelledby="partners-title"
>
  <div class="section-heading">
    <h2 id="partners-title">Партнёры</h2>
  </div>

  <div class="partner-marquee">
    <div
      class:list={['partner-track', { 'partner-track--static': !hasPartners }]}
    >
      {
        loopItems.map((item) =>
          item.type === 'partner' ? (
            <a
              class:list={[
                'partner-tile',
                { 'partner-tile--duplicate': item.isDuplicate },
              ]}
              href={item.partner.href ?? '#partners'}
              target={item.partner.href ? '_blank' : undefined}
              rel={item.partner.href ? 'noreferrer' : undefined}
            >
              <img
                src={item.partner.logoSrc}
                alt={item.partner.name}
                loading="lazy"
                decoding="async"
              />
            </a>
          ) : (
            <div
              class:list={[
                'partner-tile',
                'partner-tile--placeholder',
                { 'partner-tile--duplicate': item.isDuplicate },
              ]}
              aria-hidden="true"
            >
              <span />
            </div>
          ),
        )
      }
    </div>
  </div>
</section>
