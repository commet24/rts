---
import { partners } from '@data/partners';

const placeholders = Array.from({ length: 8 }, (_, index) => ({
  id: `placeholder-${index}`,
}));

const carouselItems =
  partners.length > 0
    ? partners.map((partner) => ({ type: 'partner' as const, partner }))
    : placeholders.map((placeholder) => ({
        type: 'placeholder' as const,
        placeholder,
      }));

const loopItems = [...carouselItems, ...carouselItems];
---

<section
  class="partners-section"
  id="partners"
  aria-labelledby="partners-title"
>
  <div class="section-heading">
    <p class="eyebrow">Партнёры</p>
    <h2 id="partners-title">Партнёрская лента</h2>
    <p>
      Секция уже готова к логотипам партнёров. Пока список пуст, лента
      показывает нейтральные плитки без выдуманных брендов.
    </p>
  </div>

  <div class="partner-marquee">
    <div class="partner-track">
      {
        loopItems.map((item) =>
          item.type === 'partner' ? (
            <a
              class="partner-tile"
              href={item.partner.href ?? '#partners'}
              target={item.partner.href ? '_blank' : undefined}
              rel={item.partner.href ? 'noreferrer' : undefined}
            >
              <img
                src={item.partner.logoSrc}
                alt={item.partner.name}
                loading="lazy"
                decoding="async"
              />
            </a>
          ) : (
            <div
              class="partner-tile partner-tile--placeholder"
              aria-hidden="true"
            >
              <span />
            </div>
          ),
        )
      }
    </div>
  </div>
</section>
